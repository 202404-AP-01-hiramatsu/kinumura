<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.TodoMapper">

    <select id="findAll" resultType="com.example.demo.entity.Todo">
        SELECT id, title
        FROM todo
        ORDER BY id DESC
    </select>

    <insert id="insert" parameterType="com.example.demo.entity.Todo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO todo (
            title
        ) VALUES (
            #{title}
        )
    </insert>

</mapper>
